# Database connection mode
# Locally we reach RDS through an SSH tunnel; in prod (running inside the VPC)
# the app connects directly to RDS via security groups. Leave this unset to
# auto-detect: tunnel when SSH_HOST is set, direct otherwise. Set explicitly to
# force a mode (true/false).
DB_USE_SSH_TUNNEL=
# Optional TLS to RDS. Use "Amazon RDS" to verify against the bundled RDS CA,
# or "true" for default TLS. Leave blank to disable TLS.
MYSQL_SSL=

# SSH tunnel (Standard TCP/IP over SSH) — local dev only. Leave SSH_HOST blank
# in prod so the app connects directly to RDS.
SSH_HOST=
SSH_PORT=22
SSH_USER=
# Path to a locally-stored private key (supports ~ for home dir)
SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa
# Optional passphrase if the key is encrypted
SSH_PASSPHRASE=

# MySQL connection settings. With the SSH tunnel, host/port are as seen from the
# SSH server. For a direct (prod) connection, set MYSQL_HOST to the RDS endpoint.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ultraviris
MYSQL_CONNECTION_LIMIT=10

# Amazon SES (contact form email)
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Verified SES sender identity (must be verified in SES)
SES_FROM_EMAIL=
# Where contact form messages are delivered
CONTACT_TO_EMAIL=ultraviris@gmail.com

# Health monitoring / alerting
# Where operational alert emails are sent (falls back to CONTACT_TO_EMAIL).
ALERT_EMAIL=
# Minutes to wait before re-sending a reminder for a still-failing check.
ALERT_RESEND_MINUTES=60
# Shared secret required to call POST/GET /api/health/cron. Use a long random
# string. An external scheduler (EventBridge, Vercel Cron, cron job, uptime
# monitor) should hit that endpoint every few minutes with this token, e.g.:
#   curl -H "Authorization: Bearer <secret>" https://yoursite/api/health/cron
HEALTH_CHECK_SECRET=

# Admin page (/admin)
# Admin accounts live in the `admin_users` DB table (passwords hashed with
# scrypt). On first run, if that table is empty, an initial account is seeded
# from the values below so you can sign in, then manage users from the admin UI.
# Username for the seeded initial admin (default: admin).
ADMIN_USERNAME=admin
# Password for the seeded initial admin. Only used to create the first account;
# afterwards, change passwords from the admin UI (this value is not re-checked).
ADMIN_PASSWORD=
# Secret used to sign the admin session cookie (use a long random string).
# Changing it invalidates all existing admin sessions.
ADMIN_SESSION_SECRET=

# SEO / canonical URLs
# Public site origin used for canonical URLs, sitemap, robots, and Open Graph
# image URLs. Defaults to https://nataliernathan.com if unset.
NEXT_PUBLIC_SITE_URL=https://nataliernathan.com

# Image storage
# Leave blank to serve images from the local `public/` directory.
# Later, set to your S3/CDN base URL (e.g. https://my-bucket.s3.amazonaws.com).
IMAGE_BASE_URL=
# S3 bucket for admin image uploads. Leave blank to store uploads locally in
# `public/` for now; set it to enable uploading to S3 (uses AWS_* credentials).
S3_BUCKET=
# When the image resolver fuzzy-matches a File_Location (wrong/missing
# extension) to a real object, it writes the corrected value back to the DB so
# the next load is exact. On by default; set to 0/false to disable.
IMAGE_AUTOHEAL=

# GitHub issue reporter (admin page)
# Fine-grained personal access token with "Issues: Read and write" on the repo
# below. Enables the in-admin "Report an issue" popout. Leave blank to disable.
GITHUB_TOKEN=
# Repository that admin-filed issues are opened against (owner/repo).
# Defaults to shsahim/ultraviris-2026 if unset.
GITHUB_ISSUE_REPO=shsahim/ultraviris-2026
