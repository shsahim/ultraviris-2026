# SSH tunnel (Standard TCP/IP over SSH)
SSH_HOST=
SSH_PORT=22
SSH_USER=
# Path to a locally-stored private key (supports ~ for home dir)
SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa
# Optional passphrase if the key is encrypted
SSH_PASSPHRASE=

# MySQL connection settings (host/port as seen from the SSH server)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ultraviris
MYSQL_CONNECTION_LIMIT=10

# Amazon SES (contact form email)
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Verified SES sender identity (must be verified in SES)
SES_FROM_EMAIL=
# Where contact form messages are delivered
CONTACT_TO_EMAIL=ultraviris@gmail.com

# Health monitoring / alerting
# Where operational alert emails are sent (falls back to CONTACT_TO_EMAIL).
ALERT_EMAIL=
# Minutes to wait before re-sending a reminder for a still-failing check.
ALERT_RESEND_MINUTES=60
# Shared secret required to call POST/GET /api/health/cron. Use a long random
# string. An external scheduler (EventBridge, Vercel Cron, cron job, uptime
# monitor) should hit that endpoint every few minutes with this token, e.g.:
#   curl -H "Authorization: Bearer <secret>" https://yoursite/api/health/cron
HEALTH_CHECK_SECRET=

# Admin page (/admin)
# Password the admin uses to sign in.
ADMIN_PASSWORD=
# Secret used to sign the admin session cookie (use a long random string).
ADMIN_SESSION_SECRET=

# Image storage
# Leave blank to serve images from the local `public/` directory.
# Later, set to your S3/CDN base URL (e.g. https://my-bucket.s3.amazonaws.com).
IMAGE_BASE_URL=
# S3 bucket for admin image uploads. Leave blank to store uploads locally in
# `public/` for now; set it to enable uploading to S3 (uses AWS_* credentials).
S3_BUCKET=
